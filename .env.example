# ===========================================================================
# Captain Kiddo — Environment Variables TEMPLATE
# ===========================================================================
# HOW TO USE:
#   1. Copy this file to ".env"      ->   cp .env.example .env
#   2. Fill in the real values below (never commit the real .env!)
#
# The real ".env" file is git-ignored (see .gitignore) so secrets stay private.
# ===========================================================================


# ---------------------------------------------------------------------------
# DATABASE (MongoDB via Prisma)
# ---------------------------------------------------------------------------
# Your MongoDB connection string. Use MongoDB Atlas (free tier works) or a
# local MongoDB. Prisma + MongoDB requires a REPLICA SET (Atlas gives this by
# default; local needs `--replSet`). The database name goes after the last "/".
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/captain_kiddo?retryWrites=true&w=majority"


# ---------------------------------------------------------------------------
# RAZORPAY (Payments — INR)
# ---------------------------------------------------------------------------
# From your Razorpay Dashboard -> Settings -> API Keys.
# Use TEST keys (rzp_test_...) while developing; LIVE keys only in production.

# Public key id — safe to expose to the browser (note NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"

# SECRET key — SERVER-SIDE ONLY. Used to verify payment signatures (HMAC).
# NEVER expose this to the client. No NEXT_PUBLIC_ prefix = stays on the server.
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"


# ---------------------------------------------------------------------------
# APP CONFIG
# ---------------------------------------------------------------------------
# The base URL of the app (used for redirects, absolute links, etc.).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
